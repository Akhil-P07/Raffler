# Copy to frontend/.env for local dev (optional) or set in Railway.
# In local dev you can leave VITE_API_BASE unset — the Vite proxy forwards
# /api to http://localhost:8000 (see vite.config.ts).

# The deployed API origin. In production set this to your API service URL.
VITE_API_BASE=https://yourapi.com

# The public site origin (where buyers land after scanning a QR).
VITE_BASE_URL=https://yoursite.com
