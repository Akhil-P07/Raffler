# Copy to backend/.env and fill in real values. NEVER commit the real .env.

# SQLite is the only backend. Leave this commented locally to use the bundled
# file (sqlite:///./raffler.db) with zero setup. In production, point it at a
# file on your mounted persistent volume (four slashes = absolute path):
# DATABASE_URL=sqlite:////data/raffler.db

# JWT signing key. MUST be >= 32 bytes or the app refuses to start.
# Generate one:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-at-least-32-random-bytes-xxxxxxxx

# Used to build QR registration URLs. MUST be HTTPS in production.
BASE_URL=https://yoursite.com

# Super-admin login (POST /auth/admin/login) — manages the premium allowlist.
ADMIN_EMAIL=admin@yoursite.com
ADMIN_PASSWORD=use-a-long-random-password

# Exact frontend origin allowed by CORS (no trailing slash, not "*").
FRONTEND_ORIGIN=https://yoursite.com

# The deployed API origin, injected into the CSP connect-src directive.
API_ORIGIN=https://yourapi.com

# --- Auth -----------------------------------------------------------------
# Google OAuth (optional). If unset, only email/password login works.
# Create credentials at https://console.cloud.google.com/apis/credentials
# (OAuth client, type "Web application") and add the redirect URI below to the
# "Authorized redirect URIs" list.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yourapi.com/auth/google/callback

# Comma-separated emails granted the club (premium) plan. Self-signup is open
# to everyone (free tier); these emails (plus any added via POST /admin/premium)
# get the club plan on signup/login.
PREMIUM_EMAILS=president@yoursite.com,treasurer@yoursite.com

# --- Email (Brevo transactional API) --------------------------------------
# Emails the buyer their ticket PDF on registration, and sends org invitations.
# Leave BREVO_API_KEY blank to disable email (everything else still works).
# Get a key at https://app.brevo.com (SMTP & API → API keys). The sender must
# be a verified Brevo sender/domain.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=raffles@yoursite.com
BREVO_SENDER_NAME=Your Club Raffles
